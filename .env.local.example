# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — ZonaRo (34.99/314.99 | 69.99/629.99 | 139.99/1259.99 RON)
STRIPE_PRICE_PLUS_MONTHLY=price_...
STRIPE_PRICE_PLUS_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ELITE_MONTHLY=price_...
STRIPE_PRICE_ELITE_YEARLY=price_...

# Stripe Coupon — promoție lansare Plus 50% off, 3 luni (repeating)
# Creează în Stripe Dashboard: 50% off, duration=repeating, duration_in_months=3
STRIPE_COUPON_PLUS_LAUNCH=coupon_...

# Resend
RESEND_API_KEY=re_...
